{
  "name": "discord-tts-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord TTS bot with SQLite-backed channel binding and per-guild voice queues.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "sync": "tsx src/registerCommands.ts",
    "register:commands": "tsx src/registerCommands.ts",
    "sync:prod": "node dist/registerCommands.js",
    "register:commands:prod": "node dist/registerCommands.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.1",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "google-tts-api": "^2.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
